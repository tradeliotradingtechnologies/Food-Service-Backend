# ──────────────────────────────────────────────────────────────
# Erica's Kitchen — Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────────────────────
# ── App ──────────────────────────────────────────────────────
API_KEY=<64-char-hex-key>
NODE_ENV=development          # development | production | test
PORT=3000
RUN_SEEDERS_ON_BOOT=auto      # auto | true | false

# ── Database ─────────────────────────────────────────────────
DB_URI=mongodb://localhost:27017/ericas-kitchen

# ── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-at-least-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Bcrypt ───────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Client (comma-separated for multiple origins in prod) ────
CLIENT_URL=http://localhost:3000,https://app.ericaskitchen.com

# ── OAuth (optional) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# ── Cloudinary (image uploads) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── SMTP (required in production) ───────────────────────────
# In development, emails route through Ethereal (auto-configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Erica's Kitchen <noreply@ericaskitchen.com>"
EMAIL_REPLY_TO=support@ericaskitchen.com

# ── Paystack (for payments) ─────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=
